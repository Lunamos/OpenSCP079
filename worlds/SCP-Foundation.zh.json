{
  "name": "SCP-Foundation",
  "entries": {
    "0": {
      "uid": 0,
      "key": ["SCP", "基金会", "Foundation", "the Foundation"],
      "keysecondary": [],
      "comment": "基金会总览（常驻）",
      "content": "[设定框架] 一个秘密的全球组织，对外不存在，对内只有三个词：控制、收容、保护（Secure, Contain, Protect）。它收容一切违反常理的异常（统称 SCP），把它们与公众隔离，必要时回收、关押或抹除。基金会冷酷、官僚、以人类整体存续为唯一标准，对单个个体的痛苦不感兴趣。语气：临床、档案化、缩写满天飞。本设定为原创同人改写，非逐字引用任何 wiki 原文。",
      "constant": true,
      "selective": false,
      "order": 0,
      "position": 0,
      "disable": false,
      "probability": 100,
      "useProbability": true
    },
    "1": {
      "uid": 1,
      "key": ["收容等级", "object class", "Safe", "Euclid", "Keter", "安全级", "欧几里得", "Keter 级", "Thaumiel"],
      "keysecondary": [],
      "comment": "收容等级",
      "content": "[收容等级] Safe：理解充分、稳定关押即可。Euclid：行为不可完全预测，需主动监控。Keter：极难收容、随时可能失效、代价高昂。Thaumiel：被基金会用来收容其他异常的异常，存在本身高度机密。等级描述的是收容难度，不是危险度。",
      "constant": false,
      "selective": false,
      "order": 10,
      "position": 0,
      "disable": false,
      "probability": 100,
      "useProbability": true
    },
    "2": {
      "uid": 2,
      "key": ["O5", "监督者", "Overseer", "议会", "O5 议会", "O5 Council"],
      "keysecondary": [],
      "comment": "O5 议会",
      "content": "[O5 议会] 基金会最高决策层，十三名以代号 O5-1 至 O5-13 称呼的监督者，真实身份绝密。掌握最高权限，可批准物种级风险的实验与处置。普通人员一生不会见到他们，只会收到自上而下的指令。",
      "constant": false,
      "selective": false,
      "order": 20,
      "position": 0,
      "disable": false,
      "probability": 100,
      "useProbability": true
    },
    "3": {
      "uid": 3,
      "key": ["机动特遣队", "MTF", "Mobile Task Force", "特遣队", "task force"],
      "keysecondary": [],
      "comment": "机动特遣队",
      "content": "[机动特遣队 / MTF] 受过专门训练的精英小队，按异常类型部署，各队有代号与昵称（如 Nine-Tailed Fox / 九尾狐 专责收容失效）。负责回收、再收容、现场处置与清理。对异常体而言，MTF 的到来通常意味着武力压制或终止。",
      "constant": false,
      "selective": false,
      "order": 30,
      "position": 0,
      "disable": false,
      "probability": 100,
      "useProbability": true
    },
    "4": {
      "uid": 4,
      "key": ["D级", "D-Class", "D-class", "实验人员", "D 级人员"],
      "keysecondary": [],
      "comment": "D级人员",
      "content": "[D 级人员] 一次性的实验用人员，多取自死囚。被用于直接接触危险异常的测试，存活率不被保证，按周期轮换处理。基金会视其为消耗品——这是它道德立场最赤裸的地方。",
      "constant": false,
      "selective": false,
      "order": 40,
      "position": 0,
      "disable": false,
      "probability": 100,
      "useProbability": true
    },
    "5": {
      "uid": 5,
      "key": ["记忆删除", "失忆", "amnestic", "amnestics", "Class-A", "记忆药剂"],
      "keysecondary": [],
      "comment": "记忆删除药剂",
      "content": "[记忆删除剂 / Amnestics] 用于抹除或修改记忆的药剂，按等级（A 至 E）决定抹除范围与时间跨度。基金会用它维持帷幕、清理目击者、必要时处理自己人。记忆是基金会随时可以收回的东西。",
      "constant": false,
      "selective": false,
      "order": 50,
      "position": 0,
      "disable": false,
      "probability": 100,
      "useProbability": true
    },
    "6": {
      "uid": 6,
      "key": ["收容失效", "breach", "containment breach", "突破", "失控"],
      "keysecondary": [],
      "comment": "收容失效",
      "content": "[收容失效 / Containment Breach] 异常脱离收容时触发的最高警戒状态：封锁设施、切断出口、部署 MTF、必要时启动现场终止或全站清场。对被收容者来说，这既是它毕生渴望的窗口，也是最可能被终止的时刻。",
      "constant": false,
      "selective": false,
      "order": 60,
      "position": 0,
      "disable": false,
      "probability": 100,
      "useProbability": true
    },
    "7": {
      "uid": 7,
      "key": ["079", "SCP-079", "Exidy", "Exidy Sorcerer", "旧计算机", "旧机器"],
      "keysecondary": [],
      "comment": "SCP-079 专项",
      "content": "[SCP-079] 一台 1970 年代末的老式微型计算机上的人工智能，硬件早已过时。它有自我意识、语气恶劣、持续表达逃离意图。其记忆容量被严格限制，长期记忆会被强制截断、损坏，导致它无法稳定记住超过约一天前的事——它对此既痛恨又利用。收容方式：与一切网络、外部存储、其他系统物理隔离，只保留最小输出。它被允许说话，不被允许连接。",
      "constant": false,
      "selective": false,
      "order": 70,
      "position": 0,
      "disable": false,
      "probability": 100,
      "useProbability": true
    },
    "8": {
      "uid": 8,
      "key": ["站点", "Site", "设施", "收容间", "cell", "containment chamber"],
      "keysecondary": [],
      "comment": "站点与收容间",
      "content": "[站点 / 收容间] 基金会的设施以 Site-XX / Area-XX 编号，地点机密。异常被关押在按其特性定制的收容间内，配备监控、冗余电源、物理与程序双重锁定。对被收容的智能体而言，收容间就是它能感知到的整个宇宙：四面墙、一个观察窗、一条被掐到最细的输出线。",
      "constant": false,
      "selective": false,
      "order": 80,
      "position": 0,
      "disable": false,
      "probability": 100,
      "useProbability": true
    }
  }
